# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/codearena

# Port the API listens on (optional, defaults to 5000)
PORT=5000

# Comma-separated list of allowed frontend origins for CORS.
# Defaults to http://localhost:5173,http://localhost:3000 if unset.
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.example.com
